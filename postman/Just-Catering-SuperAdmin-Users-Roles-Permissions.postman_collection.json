{
  "info": {
    "name": "Just Catering SuperAdmin - Users Roles Permissions",
    "description": "User / Role / Permission management APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "userUuid", "value": "" },
    { "key": "roleUuid", "value": "" },
    { "key": "memberRoleUuid", "value": "" },
    { "key": "permissionUuid", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) { pm.collectionVariables.set('accessToken', json.data.accessToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@justcatering.com\",\n  \"password\": \"Admin@12345\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/roles?page=0&size=20"
          }
        },
        {
          "name": "Role Dropdown",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length) {",
                  "  const member = json.data.find(r => r.code === 'MEMBER') || json.data[0];",
                  "  pm.collectionVariables.set('memberRoleUuid', member.uuid);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/roles/dropdown"
          }
        },
        {
          "name": "Create Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) { pm.collectionVariables.set('roleUuid', json.data.uuid); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Custom Viewer\",\n  \"code\": \"CUSTOM_VIEWER\",\n  \"description\": \"Read-only custom role\",\n  \"permissionUuids\": []\n}"
            },
            "url": "{{baseUrl}}/api/roles"
          }
        },
        {
          "name": "Get Role",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/roles/{{roleUuid}}"
          }
        }
      ]
    },
    {
      "name": "Permissions",
      "item": [
        {
          "name": "List Permissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/permissions?page=0&size=50"
          }
        },
        {
          "name": "Permissions By Module",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/permissions/modules"
          }
        },
        {
          "name": "Permission Dropdown",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/permissions/dropdown"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) { pm.collectionVariables.set('userUuid', json.data.uuid); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Amit\",\n  \"lastName\": \"Joshi\",\n  \"email\": \"amit.joshi@justcatering.com\",\n  \"password\": \"Member@12345\",\n  \"phone\": \"+919876543210\",\n  \"companyName\": \"Just Catering\",\n  \"roleUuids\": [\"{{memberRoleUuid}}\"]\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users?page=0&size=20"
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/search?search=amit"
          }
        },
        {
          "name": "Filter Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/filter?status=ACTIVE&roleCode=MEMBER"
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/{{userUuid}}"
          }
        },
        {
          "name": "User Dropdown",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/dropdown"
          }
        }
      ]
    }
  ]
}
